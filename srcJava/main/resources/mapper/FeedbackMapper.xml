<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.FeedbackMapper">

    <resultMap id="FeedbackResultMap" type="com.example.entity.Feedback">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="content" column="content"/>
        <result property="time" column="time"/>
        <result property="username" column="username"/>
        <result property="avatar" column="avatar"/>
    </resultMap>

    <insert id="insert">
        insert into `feedback` (user_id, content, time, username, avatar)
        values(#{userId}, #{content}, #{time}, #{username}, #{avatar})
    </insert>

    <select id="selectAll" resultMap="FeedbackResultMap">
        select * from `feedback` order by time desc
    </select>

    <select id="selectByUserId" resultMap="FeedbackResultMap">
        select * from `feedback` where user_id = #{userId} order by time desc
    </select>

    <select id="count" resultType="int">
        select count(*) from `feedback`
    </select>
</mapper>