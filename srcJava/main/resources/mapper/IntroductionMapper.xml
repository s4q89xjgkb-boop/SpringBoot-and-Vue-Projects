<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.IntroductionMapper">

    <resultMap id="IntroductionResultMap" type="com.example.entity.Introduction">
        <id property="id" column="id"/>
        <result property="img" column="img"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="time" column="time"/>
        <result property="categoryId" column="categoryId"/>
        <result property="status" column="status"/>
        <result property="userId" column="userId"/>
        <result property="userName" column="userName"/>
        <result property="userAvatar" column="userAvatar"/>
        <result property="categoryTitle" column="categoryTitle"/>
        <result property="description" column="description"/>
        <result property="likeCount" column="like_count"/>
        <result property="collectCount" column="collect_count"/>
        <result property="replyCount" column="reply_count"/>
        <result property="views" column="views"/>
        <result property="rejectReason" column="reject_reason"/>
    </resultMap>

    <select id="selectAll" resultMap="IntroductionResultMap">
        select i.*, 
               COALESCE(u.name, a.name) as userName, 
               COALESCE(u.avatar, a.avatar) as userAvatar, 
               c.title as categoryTitle
        from `introduction` i
        left join `user` u on i.userId = u.id
        left join `admin` a on i.userId = a.id
        left join `category` c on i.categoryId = c.id
        <where>
            <if test="title != null and title != ''">i.title like concat('%', #{title}, '%')</if>
            <if test="categoryId != null">and i.categoryId = #{categoryId}</if>
            <if test="userId != null">and i.userId = #{userId}</if>
            <if test="status != null">and i.status = #{status}</if>
        </where>
        <choose>
            <when test="orderBy == 'views'">
                order by views
                <choose>
                    <when test="orderDirection == 'asc'">asc</when>
                    <otherwise>desc</otherwise>
                </choose>
            </when>
            <when test="orderBy == 'likeCount'">
                order by like_count
                <choose>
                    <when test="orderDirection == 'asc'">asc</when>
                    <otherwise>desc</otherwise>
                </choose>
            </when>
            <when test="orderBy == 'collectCount'">
                order by collect_count
                <choose>
                    <when test="orderDirection == 'asc'">asc</when>
                    <otherwise>desc</otherwise>
                </choose>
            </when>
            <when test="orderBy == 'replyCount'">
                order by reply_count
                <choose>
                    <when test="orderDirection == 'asc'">asc</when>
                    <otherwise>desc</otherwise>
                </choose>
            </when>
            <when test="orderBy == 'time'">
                order by time
                <choose>
                    <when test="orderDirection == 'asc'">asc</when>
                    <otherwise>desc</otherwise>
                </choose>
            </when>
            <otherwise>
                order by id desc
            </otherwise>
        </choose>
    </select>

    <insert id="insert">
        insert into `introduction` (img, title, content, time, categoryId, userId, status)
        values(#{img}, #{title}, #{content}, #{time}, #{categoryId}, #{userId}, #{status})
    </insert>

    <update id="updateById">
        update `introduction`
        <set>
            <if test="img != null">img = #{img},</if>
            <if test="title != null">title = #{title},</if>
            <if test="content != null">content = #{content},</if>
            <if test="time != null">time = #{time},</if>
            <if test="categoryId != null">categoryId = #{categoryId},</if>
            <if test="userId != null">userId = #{userId},</if>
            <if test="status != null">status = #{status},</if>
            <if test="rejectReason != null">reject_reason = #{rejectReason},</if>
            <if test="views != null">views = #{views}</if>
        </set>
        where id = #{id}
    </update>

    <select id="selectById" resultMap="IntroductionResultMap">
        select i.*, 
               COALESCE(u.name, a.name) as userName, 
               COALESCE(u.avatar, a.avatar) as userAvatar, 
               c.title as categoryTitle
        from `introduction` i
        left join `user` u on i.userId = u.id
        left join `admin` a on i.userId = a.id
        left join `category` c on i.categoryId = c.id
        where i.id = #{id}
    </select>

</mapper>