<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.NewsMapper">

    <resultMap id="NewsResultMap" type="com.example.entity.News">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="img" column="img"/>
        <result property="userId" column="user_id"/>
        <result property="userName" column="userName"/>
        <result property="userAvatar" column="userAvatar"/>
        <result property="status" column="status"/>
        <result property="views" column="views"/>
        <result property="likeCount" column="like_count"/>
        <result property="replyCount" column="reply_count"/>
        <result property="collectCount" column="collect_count"/>
        <result property="time" column="time"/>
        <result property="orderBy" column="orderBy"/>
        <result property="orderDirection" column="orderDirection"/>
    </resultMap>

    <insert id="insert">
        insert into `news` (title, content, img, user_id, status, views, time)
        values(#{title}, #{content}, #{img}, #{userId}, #{status}, #{views}, #{time})
    </insert>

    <update id="updateById">
        update `news`
        <set>
            <if test="title != null">title = #{title},</if>
            <if test="content != null">content = #{content},</if>
            <if test="img != null">img = #{img},</if>
            <if test="status != null">status = #{status},</if>
            <if test="views != null">views = #{views}</if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById">
        delete from `news` where id = #{id}
    </delete>

    <select id="selectById" resultMap="NewsResultMap">
        select n.*, 
               COALESCE(u.name, a.name) as userName, 
               COALESCE(u.avatar, a.avatar) as userAvatar
        from `news` n
        left join `user` u on n.user_id = u.id
        left join `admin` a on n.user_id = a.id
        where n.id = #{id}
    </select>

    <select id="selectAll" resultMap="NewsResultMap">
        select n.*, 
               COALESCE(u.name, a.name) as userName, 
               COALESCE(u.avatar, a.avatar) as userAvatar
        from `news` n
        left join `user` u on n.user_id = u.id
        left join `admin` a on n.user_id = a.id
        <where>
            <if test="title != null and title != ''">n.title like concat('%', #{title}, '%')</if>
            <if test="status != null">and n.status = #{status}</if>
        </where>
        <choose>
            <when test="orderBy == 'views'">
                order by n.views
                <choose>
                    <when test="orderDirection == 'asc'">asc</when>
                    <otherwise>desc</otherwise>
                </choose>
            </when>
            <when test="orderBy == 'likeCount'">
                order by n.like_count
                <choose>
                    <when test="orderDirection == 'asc'">asc</when>
                    <otherwise>desc</otherwise>
                </choose>
            </when>
            <when test="orderBy == 'collectCount'">
                order by n.collect_count
                <choose>
                    <when test="orderDirection == 'asc'">asc</when>
                    <otherwise>desc</otherwise>
                </choose>
            </when>
            <when test="orderBy == 'replyCount'">
                order by n.reply_count
                <choose>
                    <when test="orderDirection == 'asc'">asc</when>
                    <otherwise>desc</otherwise>
                </choose>
            </when>
            <when test="orderBy == 'time'">
                order by n.time
                <choose>
                    <when test="orderDirection == 'asc'">asc</when>
                    <otherwise>desc</otherwise>
                </choose>
            </when>
            <otherwise>
                order by n.id desc
            </otherwise>
        </choose>
    </select>
    
    <update id="incrementReplyCount">
        update `news` set reply_count = reply_count + 1 where id = #{id}
    </update>
    
    <update id="decrementReplyCount">
        update `news` set reply_count = reply_count - 1 where id = #{id} and reply_count > 0
    </update>
    
    <update id="incrementLikeCount">
        update `news` set like_count = like_count + 1 where id = #{id}
    </update>
    
    <update id="decrementLikeCount">
        update `news` set like_count = like_count - 1 where id = #{id} and like_count > 0
    </update>
    
    <update id="incrementCollectCount">
        update `news` set collect_count = collect_count + 1 where id = #{id}
    </update>
    
    <update id="decrementCollectCount">
        update `news` set collect_count = collect_count - 1 where id = #{id} and collect_count > 0
    </update>
</mapper>