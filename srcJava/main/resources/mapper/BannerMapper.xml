<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.BannerMapper">

    <select id="selectAll" resultType="com.example.entity.Banner">
        select * from `banner`
        <where>
            <if test="title != null and title != ''">title like CONCAT('%', #{title}, '%')</if>
        </where>
        order by sort asc
    </select>

    <insert id="insert">
        insert into `banner` (img, title, link, sort, time)
        values(#{img}, #{title}, #{link}, #{sort}, #{time})
    </insert>

    <update id="updateById">
        update `banner` set img = #{img}, title = #{title}, link = #{link}, sort = #{sort} where id = #{id}
    </update>

    <delete id="deleteById">
        delete from `banner` where id = #{id}
    </delete>

    <delete id="deleteBatch">
        delete from `banner` where id in
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
