<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.ForumSectionMapper">

    <resultMap id="ForumSectionResultMap" type="com.example.entity.ForumSection">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="description" column="description"/>
        <result property="icon" column="icon"/>
        <result property="postCount" column="post_count"/>
        <result property="sort" column="sort"/>
        <result property="status" column="status"/>
        <result property="time" column="time"/>
    </resultMap>

    <select id="selectAll" resultType="com.example.entity.ForumSection">
        select * from `forum_section`
        <where>
            <if test="status != null">status = #{status}</if>
            <if test="title != null and title != ''">title = #{title}</if>
        </where>
        order by sort asc, id asc
    </select>

    <insert id="insert">
        insert into `forum_section` (title, description, icon, post_count, sort, status, time)
        values(#{title}, #{description}, #{icon}, #{postCount}, #{sort}, #{status}, #{time})
    </insert>

    <update id="updateById">
        update `forum_section`
        <set>
            <if test="title != null">title = #{title},</if>
            <if test="description != null">description = #{description},</if>
            <if test="icon != null">icon = #{icon},</if>
            <if test="postCount != null">post_count = #{postCount},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="status != null">status = #{status}</if>
        </set>
        where id = #{id}
    </update>

    <select id="selectById" resultMap="ForumSectionResultMap">
        select * from `forum_section` where id = #{id}
    </select>

    <delete id="deleteById">
        delete from `forum_section` where id = #{id}
    </delete>

</mapper>
